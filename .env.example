# YouTube Data API v3 key — VITE_ prefix is required for Vite to expose it to browser code
VITE_YOUTUBE_API_KEY=

# Datadog APM (server-side)
DD_API_KEY=
DD_ENV=local
DD_SERVICE=kranz-tv
DD_VERSION=0.1.0
DD_AGENT_HOST=localhost

# Datadog Browser RUM
VITE_DD_RUM_APP_ID=
VITE_DD_RUM_CLIENT_TOKEN=
VITE_DD_ENV=local
VITE_DD_VERSION=0.1.0
