# YouTube Data API v3 key — server-side only, never exposed to browser
YOUTUBE_API_KEY=

# SoundCloud OAuth credentials — server-side only, never exposed to browser.
# /api/soundcloud uses the client_credentials grant to mint a bearer token
# (the /resolve endpoint no longer accepts bare ?client_id= query auth).
SOUNDCLOUD_CLIENT_ID=
SOUNDCLOUD_CLIENT_SECRET=

# Datadog APM (server-side)
DD_API_KEY=
DD_ENV=local
DD_SERVICE=kranz-tv
DD_VERSION=0.1.0
DD_AGENT_HOST=localhost

# Datadog Browser RUM
VITE_DD_RUM_APP_ID=
VITE_DD_RUM_CLIENT_TOKEN=
VITE_DD_ENV=local
VITE_DD_VERSION=0.1.0
