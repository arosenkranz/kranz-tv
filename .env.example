# YouTube Data API v3 key — VITE_ prefix is required for Vite to expose it to browser code
VITE_YOUTUBE_API_KEY=

# Datadog APM (server-side)
DD_API_KEY=
DD_ENV=local
DD_SERVICE=kranz-tv
DD_VERSION=0.1.0
DD_AGENT_HOST=localhost

# Datadog Browser RUM
VITE_DD_RUM_APP_ID=
VITE_DD_RUM_CLIENT_TOKEN=
VITE_DD_ENV=local
VITE_DD_VERSION=0.1.0

# Shared Channels (KV)
# No env vars — the SHARED_CHANNELS_KV namespace is bound via wrangler.jsonc.
# For local dev, run `pnpm wrangler kv namespace create SHARED_CHANNELS_KV` and
# `pnpm wrangler kv namespace create SHARED_CHANNELS_KV --preview`, then add
# the resulting IDs to `wrangler.jsonc`. `pnpm wrangler dev` provides an
# in-memory KV emulator; use `--persist` to keep data across sessions.
