    "@testing-library/react": "16.3.2",
    "@types/node": "22.19.15",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/youtube": "0.1.2",
    "@vitejs/plugin-react": "5.2.0",
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "10.0.3",
    "eslint-plugin-react-hooks": "7.0.1",
    "fake-indexeddb": "6.2.5",
    "jsdom": "28.1.0",
    "png-to-ico": "3.0.1",
    "prettier": "3.8.1",
    "typescript": "5.9.3",
    "vite": "7.3.1",
