{
  "name": "kranz-tv",
  "version": "2.5.5",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.34.1",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --check .",
    "check": "prettier --write . && eslint --fix",
    "test:e2e": "playwright test",
    "deploy": "NITRO_PRESET=cloudflare-module vite build && wrangler deploy",
    "preview:cf": "NITRO_PRESET=cloudflare-module vite build && wrangler dev"
  },
  "dependencies": {
    "@datadog/browser-logs": "6.33.0",
    "@datadog/browser-rum": "6.33.0",
    "@tailwindcss/vite": "4.3.0",
    "@tanstack/react-router": "1.170.11",
    "@tanstack/react-start": "1.168.20",
    "@tanstack/router-plugin": "1.168.14",
    "dd-trace": "5.106.0",
    "lucide-react": "0.577.0",
    "nitro": "npm:nitro-nightly@3.0.1-20260312-093400-ba5147a5",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwindcss": "4.3.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@resvg/resvg-js": "2.6.2",
    "@tailwindcss/typography": "0.5.19",
    "@tanstack/devtools-vite": "0.7.0",
    "@tanstack/eslint-config": "0.4.0",
    "@tanstack/react-devtools": "0.10.5",
    "@tanstack/react-router-devtools": "1.167.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "22.19.19",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "@types/youtube": "0.2.0",
    "@vitejs/plugin-react": "5.2.0",
    "@vitest/coverage-v8": "3.2.6",
    "eslint": "10.0.3",
    "eslint-plugin-react-hooks": "7.1.1",
    "fake-indexeddb": "6.2.5",
    "jsdom": "28.1.0",
    "png-to-ico": "3.0.1",
    "prettier": "3.8.3",
    "typescript": "5.9.3",
    "vite": "7.3.5",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "3.2.6",
    "wrangler": "4.98.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@datadog/native-iast-taint-tracking",
      "@datadog/native-metrics",
      "@datadog/pprof",
      "dd-trace",
      "esbuild",
      "lightningcss",
      "workerd"
    ]
  }
}
