{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "kranz-tv",
  "compatibility_date": "2026-03-13",
  "compatibility_flags": ["nodejs_compat"],
  "main": ".output/server/index.mjs",
  "observability": {
    "enabled": true,
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "$DurableObject",
        "class_name": "$DurableObject",
      },
    ],
  },
  "migrations": [
    {
      "tag": "v1",
      "new_classes": ["$DurableObject"],
    },
  ],
}
