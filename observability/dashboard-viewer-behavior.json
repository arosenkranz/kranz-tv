{
  "title": "KranzTV — Viewer Behavior",
  "description": "Product analytics for KranzTV. Tracks channel popularity, engagement patterns, view mode preferences, overlay usage, and mobile vs desktop behavior.",
  "layout_type": "ordered",
  "tags": ["team:kranz"],
  "widgets": [
    {
      "definition": {
        "type": "note",
        "content": "## Channel Popularity",
        "background_color": "vivid_green",
        "font_size": "18",
        "text_align": "left",
        "show_tick": false,
        "tick_pos": "50%",
        "tick_edge": "left"
      },
      "layout": { "x": 0, "y": 0, "width": 12, "height": 1 }
    },
    {
      "definition": {
        "type": "toplist",
        "title": "Most-Watched Channels",
        "requests": [
          {
            "response_format": "scalar",
            "queries": [
              {
                "data_source": "rum",
                "name": "query1",
                "search": {
                  "query": "@action.name:channel_switch service:kranz-tv"
                },
                "indexes": ["*"],
                "compute": { "aggregation": "count" },
                "group_by": [
                  {
                    "facet": "@action.custom.to_channel",
                    "limit": 15,
                    "sort": { "aggregation": "count", "order": "desc" }
                  }
                ]
              }
            ],
            "formulas": [{ "formula": "query1" }]
          }
        ]
      },
      "layout": { "x": 0, "y": 1, "width": 6, "height": 4 }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Channel Switches Over Time",
        "requests": [
          {
            "response_format": "timeseries",
            "queries": [
              {
                "data_source": "rum",
                "name": "query1",
                "search": {
                  "query": "@action.name:channel_switch service:kranz-tv"
                },
                "indexes": ["*"],
                "compute": { "aggregation": "count" }
              }
            ],
            "formulas": [{ "formula": "query1" }],
            "display_type": "bars",
            "style": {
              "palette": "green",
              "line_type": "solid",
              "line_width": "normal"
            }
          }
        ],
        "yaxis": { "include_zero": true },
        "show_legend": false
      },
      "layout": { "x": 6, "y": 1, "width": 6, "height": 4 }
    },
